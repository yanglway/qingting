<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>全国省市区关键词查询</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
    :root {
        --primary: #4f46e5;
        --bg: #f0f2f5;
        --card: #ffffff;
        --success: #16a34a;
        --danger: #dc2626;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: "Microsoft YaHei", "Segoe UI", sans-serif;
    }

    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        padding-bottom: 150px; /* 给广告留空间 */
    }

    .box {
        width: 100%;
        max-width: 480px;
        background: var(--card);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 20px 40px rgba(0,0,0,.2);
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #333;
    }

    input {
        width: 100%;
        padding: 14px;
        font-size: 16px;
        border: 2px solid #ddd;
        border-radius: 10px;
        outline: none;
        transition: all .2s;
    }
    input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(79,70,229,.15);
    }

    .result {
        margin-top: 20px;
        font-size: 18px;
        text-align: center;
        min-height: 50px;
        line-height: 1.5;
    }
    .ok { color: var(--success); }
    .err { color: var(--danger); }

    /* ===== 显眼广告位 ===== */
    .ad-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: linear-gradient(90deg, #ff512f, #dd2476); /* 高亮渐变 */
        color: #fff;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 -8px 30px rgba(221, 36, 118, .6);
        z-index: 99999;
        animation: breathe 2s infinite alternate;
    }

    @keyframes breathe {
        from { box-shadow: 0 -8px 30px rgba(221, 36, 118, .6); }
        to { box-shadow: 0 -8px 40px rgba(255, 81, 47, .9); }
    }

    .ad-text {
        font-size: 18px;
        font-weight: bold;
        text-shadow: 1px 1px 3px rgba(0,0,0,.3);
    }
    .ad-text span {
        display: block;
        font-size: 12px;
        opacity: .9;
        margin-top: 2px;
        font-weight: normal;
    }

    .tg-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #229ed9;
        color: #fff;
        padding: 12px 20px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 16px;
        font-weight: bold;
        transition: transform .2s;
    }
    .tg-btn:hover {
        transform: scale(1.05);
    }
    .tg-btn svg {
        width: 26px;
        height: 26px;
        fill: #fff;
    }
</style>
</head>
<body>

<div class="box">
    <h2>📍 全国省市区关键词查询</h2>
    <input id="kw" placeholder="输入省 / 市 / 区县，如：新疆、喀什、达日">
    <div class="result" id="res"></div>
</div>

<!-- 显眼广告位 -->
<div class="ad-bar">
    <div class="ad-text">
        财神字花 · 赔率 1:28
        <span>点击下方图标直接联系</span>
    </div>
    <a class="tg-btn" href="https://t.me/renzhi12" target="_blank">
        <svg viewBox="0 0 240 240">
            <circle cx="120" cy="120" r="120" fill="#2ca5e0"/>
            <path d="M178.6 69.4c-2.4-1.8-14.4-7-28.2-12.4-13.8-5.4-23-9-27.8-10.8-11.8-4.2-14.4-3-16.6 2.4-1.2 3-4.8 11.4-7.8 18.6-9 21-13.2 29.4-13 31.8.2 2.4 3 3.6 6.6 2.4l15.6-5.4c3-.6 5.4-.6 6.6.6 1.2 1.2 1.2 3 0 5.4l-19.8 37.8c-1.2 2.4-2.4 4.8-4.2 6.6-2.4 2.4-4.8 3.6-7.2 3.6-3 0-5.4-.6-7.2-1.8-2.4-1.8-3.6-4.2-3.6-7.2 0-1.2.6-3 1.8-5.4l6.6-13.8c.6-1.2 0-2.4-.6-3.6l-8.4-12c-.6-.6-1.8-1.2-3.6-1.2-2.4 0-4.8 1.2-7.2 3.6l-6 6c-2.4 2.4-4.2 4.8-5.4 7.2-1.2 2.4-1.8 5.4-1.8 9 0 8.4 3.6 15.6 10.8 21.6 7.2 6 16.2 9 27 9 10.8 0 20.4-3 28.8-9 8.4-6 14.4-13.8 18-23.4l13.8-33c1.8-4.2 3.6-8.4 5.4-12.6 1.8-4.2 3-7.2 3.6-9 .6-1.8.6-3 0-3.6-.6-.6-1.8-1.2-3.6-1.2z" fill="#fff"/>
        </svg>
        Telegram
    </a>
</div>

<script>
let chinaData = null;

// 加载全国数据
fetch("https://geo.datav.aliyun.com/areas_v3/bound/100000_full.json")
.then(r => r.json())
.then(d => chinaData = d);

function search(kw) {
    if (!chinaData) return [];
    const r = [];
    for (let p of chinaData.features) {
        const pn = p.properties.name;
        if (pn.includes(kw)) { r.push({ province: pn }); continue; }
        for (let c of p.properties.children || []) {
            if (c.name.includes(kw)) { r.push({ province: pn, city: c.name }); continue; }
            for (let a of c.children || []) {
                if (a.name.includes(kw)) r.push({ province: pn, city: c.name, area: a.name });
            }
        }
    }
    return r;
}

document.getElementById("kw").addEventListener("input", () => {
    const v = document.getElementById("kw").value.trim();
    const res = document.getElementById("res");
    if (!v) { res.textContent = ""; return; }
    const list = search(v);
    if (!list.length) { res.innerHTML = "<span class='err'>未找到匹配结果</span>"; return; }
    res.innerHTML = list.map(i =>
        i.area ? `✅ ${i.province} · ${i.city} · ${i.area}` :
        i.city ? `✅ ${i.province} · ${i.city}` :
        `✅ ${i.province}`
    ).join("<br>");
    res.className = "result ok";
});
</script>

</body>
</html>
